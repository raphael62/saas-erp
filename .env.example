# Use SEPARATE Supabase projects for development vs production:
# - Local: create a dev-only project in the Supabase Dashboard, put its URL and keys in .env.local
# - Production: use your production project credentials only in Vercel (or your host) — never mix with dev
# This avoids login/data conflicts and keeps DEV_BYPASS_ORG (below) from affecting real users.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (bypasses RLS) - for org assignment fix. Get from Dashboard > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL for auth redirects (local: http://localhost:3000; production: https://masterbookserp.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Registration / company code (Option C — required for sign-up to show the 6-digit code immediately)
# In EACH Supabase project (dev + prod): Dashboard → Authentication → Providers → Email →
# turn OFF "Confirm email" (or "Enable email confirmations"). If it stays ON, users get no
# session after signUp and will not see the success screen with the company code.
# The app does not email the code; it only appears on the page after registration.

# Platform admins: comma-separated emails that bypass company code and get global access
PLATFORM_ADMIN_EMAILS=

# Dev bypass: set to "1" for local dev – any authenticated user gets access without org/company code.
# Do NOT set in production.
# DEV_BYPASS_ORG=1
# Optional: NEXT_PUBLIC_DEV_BYPASS_ORG=1 — still shows company code on login, but server skips code check (dev only).
# NEXT_PUBLIC_DEV_BYPASS_ORG=1

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
